# Нормализация концов строк: текстовые файлы в LF (кросс-платформа),
# Windows-скрипты (.bat/.vbs) принудительно в CRLF — этого требует Windows.
* text=auto eol=lf
*.bat text eol=crlf
*.vbs text eol=crlf

# Generated research artifacts should not dominate GitHub language stats.
analysis/*.html linguist-generated=true
analysis/*_study.html linguist-generated=true
