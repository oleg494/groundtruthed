# Боевой read-only токен T-Invest API (invest-public-api.tinkoff.ru). Только чтение —
# не используется ни в одном write-методе.
TINVEST_API_KEY=t.xxxxxxxx

# Токен песочницы (sandbox-invest-public-api.tinkoff.ru). Здесь можно выставлять заявки —
# деньги виртуальные. lab/, daybot/, scripts/sandbox_grid.py, backtest/candles.py.
TINVEST_SANDBOX_KEY=t.xxxxxxxx

# Свои номера брокерских счетов через запятую (analysis/*_validate.py, часть scripts/).
TINVEST_ACCOUNTS=0000000000,0000000000
